# Robinhood Chain MAINNET (chain 4663) — UniswapV2Adapter wiring config.
#
# Fill these with VERIFIED mainnet addresses before running
# script/DeployMainnetUniV2.s.sol. The script refuses to run on any address
# without code and on any router that doesn't answer factory(), so a wrong or
# empty value fails fast instead of mis-wiring the live router.
#
# Where to get the addresses (chain launched 2026-07; not yet all public):
#   • INTENT_ROUTER — your mainnet ShadowzDex IntentRouter (deploy it first, the
#     same way as testnet via DeployProve.s.sol against rh_mainnet).
#   • V2_ROUTERS    — the real Uniswap and Rialto V2 router addresses on RH Chain.
#     Source: https://docs.robinhood.com/chain/connecting , the mainnet explorer
#     (explorer.mainnet.chain.robinhood.com), Uniswap's deployment docs, or
#     chain-developers-group@robinhood.com. VERIFY each has code before use.
#   • ADMIN         — the mainnet Safe that should hold the adapter's roles.
#
# Network: rpc.mainnet.chain.robinhood.com  ·  chainId 4663

DEPLOYER_PK=0x...          # must already hold CONFIG_ROLE on INTENT_ROUTER
INTENT_ROUTER=0x...        # live mainnet IntentRouter
ADMIN=0x...                # mainnet Safe (adapter role admin)

# Comma-separated, no spaces. One entry per real V2 router to whitelist.
V2_ROUTERS=0xUniswapV2Router...,0xRialtoV2Router...

# Comma-separated venue keys to register — one per DEX. Each resolves to the
# single UniswapV2Adapter; the specific pool is chosen by adapterData at swap
# time. Match these to the "venue" fields you add to copilot/markets.json.
VENUE_KEYS=UNISWAP_V2,RIALTO_V2
