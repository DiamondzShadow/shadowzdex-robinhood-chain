# Robinhood Chain MAINNET (chain 4663) deploy config.
# Network: rpc.mainnet.chain.robinhood.com · explorer.mainnet.chain.robinhood.com
#
# Fill with VERIFIED mainnet addresses. Both scripts validate every address
# on-chain before writing (no code / wrong router / EOA admin all revert), so a
# wrong or empty value fails fast instead of mis-deploying.
#
# SEQUENCE:
#   1. DeployProveMainnet.s.sol   → deploys the IntentRouter, registers the
#      attestor, sets fees, grants admin to the Safe. Copy the emitted router
#      address into INTENT_ROUTER below. Keep RENOUNCE_DEPLOYER=false here.
#   2. DeployMainnetUniV2.s.sol    → deploys the UniswapV2Adapter + venues
#      (uses the deployer's CONFIG_ROLE, which step 1 kept).
#   3. Re-run step 1 with RENOUNCE_DEPLOYER=true (or renounce via the Safe) to
#      drop the deployer's roles once wiring is done.

DEPLOYER_PK=0x...          # broadcaster (funded; holds CONFIG_ROLE until step 3)

# ── Step 1: DeployProveMainnet (router) ──
ADMIN=0x...                # mainnet Safe — receives every admin role (MUST have code)
ATTESTOR=0x...             # CRE attestor pubkey to authorize as an intent signer
PERMIT2=0x000000000022D473030F116dDEE9F6B43aC78BA3   # canonical Permit2 — deployed on RH mainnet (verified). 0x0 disables the Permit2 path.
FEE_BPS=0                  # protocol fee on swaps (ceiling 100 = 1%); 0 = none
FEE_TREASURY=              # fee sink if FEE_BPS>0 (default = ADMIN)
PASS_DISCOUNT_BPS=0        # ShadowPass fee discount
RENOUNCE_DEPLOYER=false    # true only on the final step, after venues are wired

# ── Step 2: DeployMainnetUniV2 (adapter + venues) ──
INTENT_ROUTER=0x...        # <- the router address emitted by step 1
# Comma-separated, no spaces. Real V2 routers to whitelist. Source: the mainnet
# explorer, docs.robinhood.com/chain/connecting, Uniswap's deployment docs, or
# chain-developers-group@robinhood.com. Each is on-chain-validated (code + factory()).
V2_ROUTERS=0xUniswapV2Router...,0xRialtoV2Router...
# One venue key per DEX — each resolves to the single adapter; the pool is chosen
# by adapterData. Match these to the "venue" fields in copilot/markets.json.
VENUE_KEYS=UNISWAP_V2,RIALTO_V2
