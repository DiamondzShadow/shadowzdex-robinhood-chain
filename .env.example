# Copy to .env and fill in. .env is git-ignored — never commit real keys.

# Deployer EOA private key (funded with Robinhood Chain testnet ETH from the faucet).
# For gas-free simulation you can leave this unset — the script falls back to the
# well-known public anvil key #0, which is fine for a fork dry-run ONLY.
DEPLOYER_PK=0x...

# Attestor hot key. In production this is the Chainlink CRE attestor pubkey that
# the router authorizes via setAttestor(). For the Phase 0 proof it's a throwaway.
ATTESTOR_PK=0x...

# Robinhood Chain testnet RPC (already wired in foundry.toml as `rh_testnet`).
RH_TESTNET_RPC=https://rpc.testnet.chain.robinhood.com
